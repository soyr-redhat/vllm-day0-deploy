MODEL="nvidia/NVIDIA-Nemotron-3-Ultra-550B-A55B-NVFP4"
VRAM_GB=320
IMAGE="REPLACE_WITH_IMAGE_AT_DEPLOY_TIME"
SERVED_MODEL_NAME="nvidia/NVIDIA-Nemotron-3-Ultra-550B-A55B-NVFP4"
MAX_MODEL_LEN=4096
MAX_BATCH_TOKENS=32768
MAX_SEQS=16
GPU_UTIL=0.90
QUEUE="reserved"
PVC_SIZE="500Gi"

# Start without chunked prefill / prefix caching for initial validation.
# Add them back via EXTRA_ARGS once the model loads and serves correctly.
CHUNKED_PREFILL=false
PREFIX_CACHING=false

EXTRA_ARGS="--enforce-eager --enable-expert-parallel --kv-cache-dtype fp8 --mamba-backend flashinfer"

EXTRA_ENV=(
  "VLLM_WORKER_MULTIPROC_METHOD=spawn"
  "FLASHINFER_DISABLE_VERSION_CHECK=1"
  "PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True"
)
