MODEL="nvidia/NVIDIA-Nemotron-3-Ultra-550B-A55B-NVFP4"
VRAM_GB=640
IMAGE="vllm/vllm-openai:v0.22.0"
SERVED_MODEL_NAME="nvidia/nemotron-3-ultra"
MAX_MODEL_LEN=262144
MAX_BATCH_TOKENS=32768
MAX_SEQS=16
GPU_UTIL=0.90
QUEUE="reserved"

EXTRA_ARGS="--enable-expert-parallel --kv-cache-dtype fp8 --reasoning-parser nemotron_v3 --enable-auto-tool-choice --tool-call-parser qwen3_coder --mamba-ssm-cache-dtype float16 --mamba-backend flashinfer --enable-mamba-cache-stochastic-rounding --mamba-cache-philox-rounds 5"

EXTRA_ENV=(
  "VLLM_WORKER_MULTIPROC_METHOD=spawn"
  "SAFETENSORS_FAST_GPU=1"
  "NVIDIA_TF32_OVERRIDE=1"
)
